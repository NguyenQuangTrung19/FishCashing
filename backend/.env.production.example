# Database (Neon.tech — free tier, permanent)
# Get connection string from: https://console.neon.tech
DATABASE_URL=postgresql://fishcash:YOUR_PASSWORD@ep-xxx-yyy.ap-southeast-1.aws.neon.tech/fishcash_pos?sslmode=require

# JWT (MUST change to a strong random secret)
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_SECRET
JWT_EXPIRES_IN=365d

# App
PORT=3000
NODE_ENV=production

# CORS — allowed origins (comma-separated, or * for all)
# For native apps, * is fine since requests come from the device, not a browser origin
CORS_ORIGIN=*
